class Node{
    int val;
    Node next;
    Node(int val,Node next){
        this.val = val;
        this.next = next ;
    }
}
class MyCircularQueue {
    Node head;
    Node rear;
    public MyCircularQueue(int k) {
        head = new Node(-1,null);
        rear =head;
        for( int i =1 ; i < k;i++){
            rear.next = new Node(-1,null);
            rear = rear.next;
        }
        rear.next = head;
        
    }
    
    public boolean enQueue(int value) {
        if(head==rear.next && head.val!=-1)return false;

         rear.next.val = value;
         rear = rear.next;
         return true;
    }
    
    public boolean deQueue() {
        if(head==rear.next  && head.val==-1)return false;
        head.val = -1; 
        head = head.next;
        return true;
    }
    
    public int Front() {
        return head.val;
    }
    
    public int Rear() {
        return rear.val;
    }
    
    public boolean isEmpty() {
        if(head==rear.next  && head.val==-1)return true;
        return false;
    }
    
    public boolean isFull() {
        if(head==rear.next && head.val!=-1)return true;
        return false;
    }
}

