class Node{
    int val;
    int key;
    Node next;
    Node prev;
    Node(int key ,int val){
        this.val = val;
        this.key = key ;
    }
}
class LRUCache {
    Node head;
    Node tail;
    int len = 0;
    Map<Integer,Node> map;
    int cap ;
    public LRUCache(int capacity) {
        map = new HashMap<>();
        head = new Node(-1,-1);
        tail = new Node(-1,-1);
        head.next = tail;
        tail.prev = head;
        this.cap = capacity;
    }
    public void insertAtHead(Node n){
            n.next = head.next;
            n.prev = head;
            head.next.prev = n;
            head.next = n;
    }
    public void deleteTheNode(Node n){
        n.next.prev = n.prev;
        n.prev.next = n.next;
    }

    public int get(int key) {
        if(!map.containsKey(key)){
        return -1;
        }
        deleteTheNode(map.get(key));
        insertAtHead(map.get(key));
        return map.get(key).val;
    }
    
    public void put(int key, int value) {
        if(map.containsKey(key)){
            map.get(key).val = value;
            deleteTheNode(map.get(key));
            insertAtHead(map.get(key));

        }
        else{
            Node n = new Node(key,value);
            if(len<cap){
                len++;
                insertAtHead(n);
                map.put(key,n);

            }
            else{
                Node toBeDleted = tail.prev;
                deleteTheNode(toBeDleted);
                map.remove(toBeDleted.key);
                insertAtHead(n);
                 map.put(key,n);
            }
        }
        
    }
}

