class Solution {
    public int[] occurrencesOfElement(int[] nums, int[] queries, int x) {
        ListInteger occurances = new ArrayList();
        int[] restult = new int[queries.length];
        for( int i=0;inums.length;i++){
            if(nums[i]==x)occurances.add(i);
        }

        for( int i=0;iqueries.length;i++){
          restult[i] = queries[i]-1  occurances.size()  occurances.get(queries[i]-1) -1;
        }
        return restult;
    }
