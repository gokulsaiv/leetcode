class Solution {
    public int mySqrt(int x) {
         long low= 1,high=x/2;
        if(x<=1)return x;
        while(low<=high){
              long mid = (low+(high-low)/2);
            if(mid*mid == x)return (int)mid;
            if(mid* mid > x)high=mid-1;
            else low= mid +1;
        }
        return (int)high;
    }
}
