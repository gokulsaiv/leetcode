class Solution {    
    int[][] dp;
    public int dfs(int i , int j , int[][] grid){
        if(i == 0 && j == 0)return 1;
        if(dp[i][j]!=-1)return dp[i][j];
        int down = (i!=0 && grid[i-1][j]!=1) ? dfs(i-1,j,grid) : 0;

         int righ = (j!=0 && grid[i][j-1]!=1) ? dfs(i,j-1,grid) : 0;

         return dp[i][j] = down + righ ; 

    }
    public int uniquePathsWithObstacles(int[][] grid) {
        if(grid[grid.length-1][grid[0].length-1]==1 || grid[0][0]==1)return 0;
        dp = new int[grid.length][grid[0].length];
        for(int i =0 ; i< grid.length ; i++)Arrays.fill(dp[i],-1);
        return dfs(grid.length-1,grid[0].length-1,grid);
    }
}

