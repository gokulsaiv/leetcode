class Solution {
    int[][] dp ;
    public int uniquePaths(int m, int n) {
        dp = new int[m+1][n+1];
        for(int i =0 ;i < m ; i++){
            dp[i][0] = 1;

        }

        for(int i =0 ;i < n ; i++){
            dp[0][i] = 1;
            
        }

        for(int i =1 ; i<m ;i++){
            for( int j =1 ; j <n;j++){
            int down = i!=0 ? dp[i-1][j] : 0;

            int right = j!=0 ? dp[i][j-1]:0;

             dp[i][j] = right + down ;
            }
        }

        return dp[m-1][n-1];
    }
}
