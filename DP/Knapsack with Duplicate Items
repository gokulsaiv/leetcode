class Solution {
    int[][] dp;
    public int dfs( int i , int W , int[] val , int[] wt){
        if(W==0)return 0;
        if(i==0){
            return (W/wt[0])*val[0];
        }
        if(dp[i][W]!=-1)return dp[i][W];
        int include = 0 ;
        if(W>=wt[i])include = val[i] + dfs(i,W-wt[i],val,wt);
        
        int exclude  = dfs(i-1,W,val,wt);
        
        return dp[i][W] = Math.max(include , exclude);
    }
   
    public  int knapSack(int val[], int wt[], int capacity) {
        dp = new int[val.length][capacity+1];
        for(int i =0 ;i < val.length;i++)Arrays.fill(dp[i],-1);
        return dfs(val.length-1,capacity,val,wt);
    }
}

