class Solution {
 
    public double fractionalKnapsack(int[] val, int[] wt, int capacity) {
        // code here
       PriorityQueue<Factions> pq = new PriorityQueue<>((a,b)->{
           return Double.compare(b.ratio,a.ratio);});
       for( int i =0 ;i < wt.length ; i++){
           pq.offer(new Factions(wt[i],val[i],(double)val[i]/wt[i]));
       }
       double profit = 0;
       while(!pq.isEmpty() && capacity > 0 ){
           Factions current = pq.poll();
           
           if(capacity >= current.wt){
               profit = profit + current.val;
               capacity = capacity - current.wt;
           }
           else{
                profit = profit + capacity * (double)current.val/current.wt;

               capacity = 0;
           }
       }
       return profit;
    }
}
class Factions {
    int wt;
    int val;
    double ratio;
    Factions( int wt,int val , double ratio){
        this.wt= wt;
        this.val = val;
        this.ratio = ratio;
    }
    
}
