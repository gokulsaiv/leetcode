class Solution {
    public void combinationSum2Help(int i, int[] nums, int target,List<Integer> temp,List<List<Integer>> ans){
        if(target == 0){
            ans.add(new ArrayList<>(temp));
            return;
        }
        if(target<0 || i >=nums.length)return;

        if(nums[i]<=target){
            temp.add(nums[i]);
            combinationSum2Help(i+1,nums,target-nums[i],temp,ans);
            temp.remove(temp.size()-1);
        }
        int j =i;
        while(j<nums.length-1 && nums[j]==nums[j+1])j++;
        combinationSum2Help(j+1,nums,target,temp,ans);
        
    }
    public List<List<Integer>> combinationSum2(int[] nums, int target) {
        Arrays.sort(nums);
        List<Integer> temp = new ArrayList<>();
        List<List<Integer>> ans = new ArrayList<>();
         combinationSum2Help(0,nums,target,temp,ans);
         return ans;
    }
}
