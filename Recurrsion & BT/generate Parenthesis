class Solution {
    public void parenthesesGenerator(int open , int close , List<Character> temp , List<String> ans){
        if(open == 0 && close == 0 ){
            StringBuilder s =new StringBuilder();
            for(int i = 0 ; i < temp.size() ; i++){
                s.append(temp.get(i));
            }
            ans.add(s.toString());
            return;
        }
        if(open>0){
            temp.add('(');
            parenthesesGenerator(open -1 , close , temp , ans);
            temp.remove(temp.size()-1);
        }

        if(close > open){
            temp.add(')');
            parenthesesGenerator(open  , close -1, temp , ans);
            temp.remove(temp.size()-1);
        }
    }
    public List<String> generateParenthesis(int n) {
        List<Character> temp = new ArrayList<>();
        List<String> ans = new ArrayList<>();
        parenthesesGenerator(n,n,temp,ans);
        return ans;

    }
}
