import java.util.*;
class Solution {
    public void sum(List<Integer> temp,List<List<Integer>> ans,int i,int[] candidates, int target){
        int s=0;
        for(int n:temp)s=s+n;
        if(s==target){
            ans.add(new ArrayList<>(temp));
            return;
            
        }
        if(s>target)return;

        for(int j=i;j<candidates.length;j++){
            temp.add(candidates[j]);
            sum(temp,ans,j,candidates,target);
            temp.remove(temp.size() - 1);
        }
    }

    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        List<Integer> temp = new ArrayList<>();
        List<List<Integer>> ans = new ArrayList<>();
        sum(temp,ans,0,candidates,target);
        return ans;
    }
}


second time soltion 


import java.util.*;

class Solution {
    public void sum(List<Integer> temp, List<List<Integer>> ans, int i, int[] candidates, int target) {
        if (target == 0) {
            ans.add(new ArrayList<>(temp));
            return;
        }

        for (int j = i; j < candidates.length; j++) {
            if (candidates[j] > target) break; // No need to continue if candidate is bigger than remaining target

            temp.add(candidates[j]);
            sum(temp, ans, j, candidates, target - candidates[j]); // Pass reduced target
            temp.remove(temp.size() - 1);
        }
    }

    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        Arrays.sort(candidates);  // Sort to optimize pruning
        List<Integer> temp = new ArrayList<>();
        List<List<Integer>> ans = new ArrayList<>();
        sum(temp, ans, 0, candidates, target);
        return ans;
    }
}

