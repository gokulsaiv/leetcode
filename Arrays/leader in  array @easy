class Solution {
    static ArrayList<Integer> leaders(int arr[]) {
        // code here
        ArrayList<Integer> result = new ArrayList<Integer>();
        int curMax = Integer.MIN_VALUE;
        for(int i = arr.length-1;i>=0;i--){
            if(arr[i] >= curMax){
                curMax = arr[i];
                result.add(0,arr[i]);
            }
        }
        return result;
    }
}
