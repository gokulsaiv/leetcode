class Solution {
    public int[] twoSum(int[] nums, int target) {
        int i =0 , j = nums.length-1;
        while(i<j){
            int sum = nums[i] + nums[j];
            if(sum == target) return new int[]{i+!,j+1};
            if(sum>target)j--;
            else i++;
        }
        return new int[]{i,j};
    }
}
