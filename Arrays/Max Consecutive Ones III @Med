class Solution {
    public int longestOnes(int[] nums, int k) {
        int  j  = 0 , i = 0  , max = Integer.MIN_VALUE;
        
        while( j < nums.length){

            if(nums[j]==0)k--;
            j++;
            if(k<0)max = Math.max(max,j-i-1);

            while(i < nums.length &&  k<0 ){
                if(nums[i]==0)k++;
                i++;
            }

        }

        if(k>=0)max = Math.max(max,j-i);
        return max;
    }
}
