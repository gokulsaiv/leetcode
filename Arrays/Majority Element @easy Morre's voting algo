class Solution {
    public int majorityElement(int[] nums) {
        int index = 0,element = 0 , freq =0 ;
        while(index < nums.length){
            if(freq == 0){
                element =  nums[index];
                freq++;
            }
            else if(element == nums[index])freq++;
            else if(nums[index] != element){
                freq--;
            }
            index++;
        }

        return element;

    }
}
