class Solution {
    public long subarrayXor(int arr[], int k) {
        // code here
        int xor = 0 , count = 0 ;
        Map<Integer,Integer> pre = new HashMap<>();
        pre.put(0,1);
        for( int i= 0 ; i < arr.length ; i++){
            xor = xor ^ arr[i];
            
            if(pre.containsKey(k ^ xor)){
                count+=pre.get(k ^ xor);
            }
            
           pre.put(xor, pre.getOrDefault(xor, 0) + 1);

        }
        return count;
    }
}
