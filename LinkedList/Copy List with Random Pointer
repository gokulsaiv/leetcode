class Solution {
    public Node copyRandomList(Node head) {
        if(head==null)return null;
        Map<Node,Node> list = new HashMap<>();
        Node temp = head;
        while(temp!=null){
            list.put(temp,new Node(temp.val));
            temp = temp.next;
        }
        temp = head;
        while(temp!=null){
            Node curr = list.get(temp);
            Node nextNode = temp.next!=null ? list.get(temp.next) : null;
            Node random = temp.random!=null ? list.get(temp.random) : null;

            curr.next = nextNode;
            curr.random = random;

            temp = temp.next;


        }
        return list.get(head);
    }
}
