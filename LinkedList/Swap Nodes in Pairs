SIMLIPER
class Solution {
    public ListNode swapPairs(ListNode head) {
        ListNode dummy = new ListNode(0);
        dummy.next = head;

        ListNode curr = dummy;

        while (curr.next != null && curr.next.next != null) {
            ListNode first = curr.next;
            ListNode second = curr.next.next;

            // swap
            first.next = second.next;
            second.next = first;
            curr.next = second;

            curr = first;
        }

        return dummy.next;
    }
}

MINE

class Solution {
    public ListNode swapPairs(ListNode head) {
        if(head == null || head.next == null)return head;
        ListNode list1 = new ListNode(-1);
        ListNode list2 = new ListNode(-1);
        ListNode list1Pointer = list1 ,  list2Pointer = list2;
        boolean evenIndex = true;
        ListNode temp = head;
        while(temp!=null){
            if(evenIndex){
                list1Pointer.next =  temp;
                list1Pointer = list1Pointer.next;
                evenIndex = false;
            }
            else{
                list2Pointer.next =  temp;
                list2Pointer = list2Pointer.next;
                evenIndex = true;
            }
            temp = temp.next;
        }
        list1Pointer.next = null;
        list2Pointer.next = null;
        ListNode combinedList = new ListNode(-1);
        ListNode swappedList =  combinedList;
        list1 = list1.next;
        list2 = list2.next;
        evenIndex = true;
        while(list1!=null && list2!=null){

            if(evenIndex){
                swappedList.next = list2;
                list2 = list2.next;
                evenIndex = false;
                
            }
            else{
                swappedList.next = list1;
                list1 = list1.next;
                evenIndex = true;
            }
            swappedList = swappedList.next;
        }
        if(list1!=null)swappedList.next = list1;
        
        return combinedList.next;
    }
}
