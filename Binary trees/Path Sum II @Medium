/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public void pathSumHelper(TreeNode root, int targetSum , int currSum,List<List<Integer>> ans , List<Integer> paths){
        
        if(root==null)return;
        paths.add(root.val);
        if((currSum + root.val)   == targetSum && root.left== null && root.right==null){
            ans.add(new ArrayList<>(paths));
            return;
        }

        
        
        pathSumHelper(root.left,targetSum,currSum + root.val, ans, paths);
        if(root.left!=null)paths.remove(paths.size()-1);
        pathSumHelper(root.right,targetSum,currSum + root.val, ans, paths);
        if(root.right!=null)paths.remove(paths.size()-1);


    }
    public List<List<Integer>> pathSum(TreeNode root, int targetSum) {
        List<List<Integer>> ans = new ArrayList<>();
        List<Integer> paths = new ArrayList<>();
        pathSumHelper(root,targetSum,0,ans,paths);
        return ans;
    }
}
