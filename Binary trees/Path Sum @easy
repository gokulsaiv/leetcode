/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public boolean hasPathSumWorker(TreeNode root, int sum , int target){
        if(root == null) return false;
        
        sum = sum + root.val;
        if(sum == target && root.left == null && root.right == null) return true;
        if(hasPathSumWorker(root.left , sum , target))return true;;
        if(hasPathSumWorker(root.right , sum , target))return true;
        return false;
    }
    public boolean hasPathSum(TreeNode root, int targetSum) {
        return hasPathSumWorker(root, 0 , targetSum);
    }
}
